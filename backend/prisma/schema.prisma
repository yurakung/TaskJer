// ไฟล์นี้คือหัวใจหลักที่ใช้กำหนดโครงสร้างฐานข้อมูลทั้งหมด

generator client {
  provider = "prisma-client-js"
}

// 1. เปลี่ยนจาก postgresql เป็น mysql
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 2. สร้างโครงสร้างตาราง User
model User {
  id        Int      @id @default(autoincrement()) // รหัสผู้ใช้ (รันเลขอัตโนมัติ)
  name      String // ชื่อผู้ใช้ (ที่รับมาจากหน้า Register)
  email     String   @unique // อีเมล (ห้ามซ้ำกัน)
  password  String // รหัสผ่าน (เดี๋ยวเราจะเข้ารหัสก่อนบันทึก)
  role      String   @default("user") // สิทธิ์ผู้ใช้งาน เช่น head, vice head, user
  createdAt DateTime @default(now()) // วันที่สมัครสมาชิก
  updatedAt DateTime @updatedAt // วันที่อัปเดตข้อมูลล่าสุด
  projects  Project[]
  joinedProjects ProjectMember[]
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   // ชื่อโปรเจค
  description String?  // รายละเอียด (มีหรือไม่มีก็ได้)
  progress    Int      @default(0) // ความคืบหน้า (0-100%)
  // ส่วนที่ใช้ผูกว่าใครเป็นคนสร้างโปรเจคนี้
  userId      Int      
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  members     ProjectMember[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String   // ชื่องานย่อย
  status      String   @default("todo") // สถานะงาน (เช่น todo, doing, done)
  
  // ส่วนที่ผูกว่างานนี้เป็นของโปรเจค ID อะไร
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int
  role      String   @default("member") // ตำแหน่ง (เช่น member, viewer)

  // ผูกความสัมพันธ์
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  // ป้องกันการเชิญคนเดียวกันเข้าโปรเจคเดิมซ้ำ 2 รอบ
  @@unique([projectId, userId]) 
}